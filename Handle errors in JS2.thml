<html>
    <head>
        <title>Handle errors in JS</title>

    </head>
    <style>
        body{
            background-color: aquamarine;
            font-size: 24;
            color: black;
            text-align: center;
        }
        h1::before{
            content: "💖"
        }
        h1::after{
            content: "💖"
        }
    </style>
    <body>
        <h1>Handle errors in JS</h1>
        <div id="result"></div>
        <script>
            try{
                var a = 30
                var b = 0
                var c = a/b
                document.getElementById("result").innerHTML = "The answer is " + c
            }
            catch(err)
            {
                document.getElementById("result").innerHTML = "The err is  " + err.mesage 
            }
        </script>
    </body>
</html>